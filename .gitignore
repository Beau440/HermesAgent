# Secrets — never commit real credentials
.env
.env.*
!.env.example
*.key
*.pem
secrets/
config/credentials*.json
config/*private*
config/*secret*

# Logs & runtime
logs/*
!logs/.gitkeep
*.log

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local notes that may contain machine-specific paths or copied terminal output
local-notes/
*.local.md

# Python (if you run Hermes tooling locally)
__pycache__/
*.pyc
.venv/
venv/
