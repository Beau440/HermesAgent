# Copy this file to ".env" and fill in real values. NEVER commit ".env".

# --- Model / LLM provider ---
# Current observed provider/model: OpenAI Codex / gpt-5.5
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
HERMES_MODEL=gpt-5.5
HERMES_PROVIDER=openai-codex

# --- Discord / Telegram (chat channels) ---
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=   # comma-separated, restrict who can talk to the agent

# --- Deployment / VPS ---
VPS_HOST=
VPS_USER=
VPS_PROVIDER=
VPS_DASHBOARD_URL=

# --- Misc integrations ---
GITHUB_TOKEN=
